<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 7.0//EN"
        "https://struts.apache.org/dtds/struts-7.0.dtd">

<struts>
    <package name="default" namespace="/" extends="struts-default">
        
        <action name="showRegister">
            <result>/WEB-INF/views/register.jsp</result>
        </action>

        <action name="register" class="com.yourcompany.registration.action.RegisterAction">
            <result name="success">/WEB-INF/views/success.jsp</result>
            <result name="error">/WEB-INF/views/register.jsp</result>
            <result name="input">/WEB-INF/views/register.jsp</result>
        </action>
        
    </package>
</struts>